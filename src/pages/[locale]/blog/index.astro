---
import { getCollection } from 'astro:content';

import { Background } from '@/components/background';
import { BlogPosts } from '@/components/blocks/blog-posts';
import { SITE_TITLE } from '@/consts';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { useTranslations, type Locale, locales } from '@/i18n/translations';

// Get the locale from the URL parameter
export async function getStaticPaths() {
  return locales.map((locale) => ({
    params: { locale },
  }));
}

const { locale } = Astro.params;
const currentLocale = locale as Locale;

// Get translations
const t = useTranslations(currentLocale);

// Get all blog posts
const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Filter posts by current language (show posts in current language + posts without lang field)
const posts = allPosts.filter(post => 
	!post.data.lang || post.data.lang === currentLocale
);
---

<DefaultLayout title={`${t('blog.title')} - ${SITE_TITLE}`} description={t('blog.description')} >
	<Background>
		<div class="py-28 lg:pt-44 lg:pb-32">
			<BlogPosts 
				posts={posts} 
				locale={currentLocale}
				translations={{
					title: t('blog.title'),
					description: t('blog.description'),
					minRead: t('blog.minRead'),
					readMore: t('blog.readMore')
				}}
				client:only='react' 
			/>
		</div>
	</Background>
</DefaultLayout>
