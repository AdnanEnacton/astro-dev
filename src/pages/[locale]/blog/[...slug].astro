---
import { getCollection, render } from 'astro:content';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { BlogPost } from '@/components/blocks/blog-post';
import { useTranslations, type Locale, locales } from '@/i18n/translations';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  
  // Generate paths for all locales and their posts
  const paths = [];
  
  for (const locale of locales) {
    for (const post of posts) {
      // Posts are organized in locale folders: en/post-name, es/post-name, pt-br/post-name
      // The post.id includes the folder prefix, e.g. "en/post-1-ad"
      const postLocale = post.id.split('/')[0];
      
      // Only include posts that belong to this locale
      if (postLocale !== locale) {
        continue;
      }
      
      // The slug is the post id without the locale prefix
      const slug = post.id.split('/').slice(1).join('/');
      
      paths.push({
        params: { 
          locale: locale,
          slug: slug 
        },
        props: { post, locale },
      });
    }
  }
  
  return paths;
}

const { post, locale } = Astro.props;
const currentLocale = locale as Locale;
const t = useTranslations(currentLocale);

const { Content } = await render(post);
---

<DefaultLayout title={post.data.title} description={post.data.description}>
  <BlogPost post={post} locale={currentLocale} client:only='react'>
    <Content />
  </BlogPost>
</DefaultLayout>
