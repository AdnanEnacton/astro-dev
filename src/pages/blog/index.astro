---
import { getCollection } from 'astro:content';

import { Background } from '@/components/background';
import { BlogPosts } from '@/components/blocks/blog-posts';
import { SITE_TITLE } from '@/consts';
import { useTranslations } from '@/i18n/translations';
import DefaultLayout from '@/layouts/DefaultLayout.astro';

const currentLocale = 'en';
const t = useTranslations(currentLocale);

// Get all blog posts
const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Filter posts by locale folder (post.id starts with locale prefix, e.g. "en/post-name")
const posts = allPosts.filter(post => 
	post.id.startsWith(`${currentLocale}/`)
);
---

<DefaultLayout title={`${t('blog.title')} - ${SITE_TITLE}`} description={t('blog.description')} >
	<Background>
		<div class="py-28 lg:pt-44 lg:pb-32">
			<BlogPosts 
				posts={posts} 
				locale={currentLocale}
				translations={{
					title: t('blog.title'),
					description: t('blog.description'),
					minRead: t('blog.minRead'),
					readMore: t('blog.readMore')
				}}
				client:only='react' 
			/>
		</div>
	</Background>
</DefaultLayout>
		</div>
	</Background>
</DefaultLayout>
