---
import { ArrowLeft } from "lucide-react";

import { Background } from "@/components/background";
import { Button } from "@/components/ui/button";
import BasicLayout from "@/layouts/BasicLayout.astro";
import DefaultLayout from "@/layouts/DefaultLayout.astro";

---

<DefaultLayout title="404: Not Found" description="Sorry, the page you're looking for doesn't exist.">
  <Background>
    <div class="flex flex-col justify-center items-center py-28 lg:py-32 min-h-[70vh] lg:min-h-[80vh] text-center container">
      <div class="z-10 relative max-w-2xl">
        <h1 class="relative bg-clip-text bg-linear-to-br from-foreground to-foreground/70 mb-6 py-2 font-bold text-transparent text-5xl sm:text-6xl lg:text-7xl">
          Page Not Found
        </h1>

        <p class="mb-10 text-muted-foreground text-xl">
          Sorry, we couldn't find the page you're looking for. The page might
          have been removed or the URL might be incorrect.
        </p>

        <div class="flex sm:flex-row flex-col sm:justify-center items-center gap-4">
          <a href="/">
          <Button size="lg" className="group gap-2 min-w-[200px]">
              <ArrowLeft className="size-5 transition-transform group-hover:-translate-x-1" />
              Back to Home
            </Button>
          </a>
          <a href="/contact">
            <Button
            variant="outline"
            size="lg"
            className="min-w-[200px]"
            >
              Contact Support
            </Button>
           </a>
        </div>
      </div>
    </div>
  </Background>
</DefaultLayout> 